generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Accounts & roles ────────────────────────────────────────────────────────

enum Role {
  ADMIN
  PLAYER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(PLAYER)
  pushToken    String? // Expo push token
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  player       Player?
  notifications Notification[]
  coachMessages CoachMessage[]
}

// ─── Players ─────────────────────────────────────────────────────────────────

enum BattingStyle {
  RIGHT_HAND
  LEFT_HAND
}

enum BowlingStyle {
  RIGHT_ARM_FAST
  RIGHT_ARM_MEDIUM
  RIGHT_ARM_OFF_SPIN
  RIGHT_ARM_LEG_SPIN
  LEFT_ARM_FAST
  LEFT_ARM_MEDIUM
  LEFT_ARM_ORTHODOX
  LEFT_ARM_CHINAMAN
  NONE
}

enum PlayingRole {
  BATSMAN
  BOWLER
  ALL_ROUNDER
  WICKET_KEEPER
  UNKNOWN
}

model Player {
  id           String        @id @default(cuid())
  userId       String?       @unique
  user         User?         @relation(fields: [userId], references: [id])
  name         String
  normalizedName String      @unique // lowercase, for commentary name matching
  cricheroesId Int?          @unique // CricHeroes player id, for exact match on JSON ingest
  photoUrl     String?
  jerseyNumber Int?
  battingStyle BattingStyle?
  bowlingStyle BowlingStyle  @default(NONE)
  playingRole  PlayingRole   @default(UNKNOWN)
  isActive     Boolean       @default(true)
  autoCreated  Boolean       @default(false) // created by commentary parser
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  battingInnings   BattingInnings[]
  bowlingSpells    BowlingSpell[]
  fieldingEfforts  FieldingEffort[]
  trainingLogs     TrainingLog[]
  exerciseLogs     ExerciseLog[]
  attendance       AttendanceRecord[]
  rsvps            Rsvp[]
  disciplineScores DisciplineScore[]
  rankingSnapshots RankingSnapshot[]
  insights         AiInsight[]
  dismissals       BallEvent[]        @relation("DismissedPlayer")
}

// ─── Matches & commentary ────────────────────────────────────────────────────

enum MatchResult {
  WON
  LOST
  TIED
  DRAW
  NO_RESULT
}

model Match {
  id          String       @id @default(cuid())
  title       String
  opponent    String
  venue       String?
  date        DateTime
  overs       Int? // match format, e.g. 20
  result      MatchResult?
  resultText  String? // "FAB CC won by 24 runs"
  rawCommentary String? // original uploaded text, kept for audit/reparse
  createdAt   DateTime     @default(now())

  innings Innings[]
}

model Innings {
  id           String  @id @default(cuid())
  matchId      String
  match        Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  number       Int // 1 or 2
  battingTeam  String
  totalRuns    Int     @default(0)
  totalWickets Int     @default(0)
  totalOvers   String? // "19.4"

  balls           BallEvent[]
  battingInnings  BattingInnings[]
  bowlingSpells   BowlingSpell[]
  fieldingEfforts FieldingEffort[]

  @@unique([matchId, number])
}

enum DismissalType {
  BOWLED
  CAUGHT
  LBW
  RUN_OUT
  STUMPED
  HIT_WICKET
  CAUGHT_AND_BOWLED
  RETIRED
  OTHER
}

model BallEvent {
  id            String         @id @default(cuid())
  inningsId     String
  innings       Innings        @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  over          Int
  ballInOver    Int
  batterName    String
  bowlerName    String
  runsBat       Int            @default(0)
  extras        Int            @default(0)
  extraType     String? // wide | no-ball | bye | leg-bye
  isFour        Boolean        @default(false)
  isSix         Boolean        @default(false)
  isWicket      Boolean        @default(false)
  dismissalType DismissalType?
  dismissedId   String?
  dismissed     Player?        @relation("DismissedPlayer", fields: [dismissedId], references: [id])
  fielderName   String?
  commentary    String

  @@index([inningsId, over, ballInOver])
}

// ─── Derived scorecards ──────────────────────────────────────────────────────

model BattingInnings {
  id            String         @id @default(cuid())
  playerId      String
  player        Player         @relation(fields: [playerId], references: [id])
  inningsId     String
  innings       Innings        @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  runs          Int            @default(0)
  balls         Int            @default(0)
  fours         Int            @default(0)
  sixes         Int            @default(0)
  isOut         Boolean        @default(false)
  dismissalType DismissalType?
  dismissedBy   String? // bowler name
  battingOrder  Int

  @@unique([playerId, inningsId])
}

model BowlingSpell {
  id        String  @id @default(cuid())
  playerId  String
  player    Player  @relation(fields: [playerId], references: [id])
  inningsId String
  innings   Innings @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  balls     Int     @default(0) // legal deliveries
  runs      Int     @default(0)
  wickets   Int     @default(0)
  maidens   Int     @default(0)
  wides     Int     @default(0)
  noBalls   Int     @default(0)

  @@unique([playerId, inningsId])
}

model FieldingEffort {
  id        String  @id @default(cuid())
  playerId  String
  player    Player  @relation(fields: [playerId], references: [id])
  inningsId String
  innings   Innings @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  catches   Int     @default(0)
  runOuts   Int     @default(0)
  stumpings Int     @default(0)

  @@unique([playerId, inningsId])
}

// ─── Events, RSVP, attendance ────────────────────────────────────────────────

enum EventType {
  MATCH
  PRACTICE
  FITNESS
  GYM
  RUNNING
  TEAM_MEETING
  STRATEGY_MEETING
  TOURNAMENT
  CAMP
  OTHER
}

enum RsvpStatus {
  ACCEPTED
  DECLINED
  MAYBE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model Event {
  id          String    @id @default(cuid())
  type        EventType
  title       String
  description String?
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  venue       String?
  latitude    Float?
  longitude   Float?
  coach       String?
  maxPlayers  Int?
  notes       String?
  createdAt   DateTime  @default(now())

  // Reminder push flags so each reminder is sent at most once.
  remindedDayBefore  Boolean @default(false)
  remindedHourBefore Boolean @default(false)

  rsvps      Rsvp[]
  attendance AttendanceRecord[]
}

model Rsvp {
  id       String     @id @default(cuid())
  eventId  String
  event    Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  playerId String
  player   Player     @relation(fields: [playerId], references: [id])
  status   RsvpStatus
  updatedAt DateTime  @updatedAt

  @@unique([eventId, playerId])
}

model AttendanceRecord {
  id       String           @id @default(cuid())
  eventId  String
  event    Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  playerId String
  player   Player           @relation(fields: [playerId], references: [id])
  status   AttendanceStatus
  markedAt DateTime         @default(now())

  @@unique([eventId, playerId])
}

// ─── Training & exercise ─────────────────────────────────────────────────────

enum TrainingType {
  BATTING_NETS
  BOWLING_NETS
  MACHINE_BOWLING
  MANUAL_BOWLING
  THROWDOWNS
  FIELDING_PRACTICE
  SLIP_CATCHING
  HIGH_CATCH
  GROUND_FIELDING
  THROW_ACCURACY
  WICKET_KEEPING
  FITNESS
  STRENGTH_TRAINING
  MOBILITY
  RECOVERY
  SPRINT_TRAINING
  RUNNING
  GYM
  YOGA
  STRETCHING
  SWIMMING
  CYCLING
  OTHER
}

model TrainingLog {
  id          String       @id @default(cuid())
  playerId    String
  player      Player       @relation(fields: [playerId], references: [id])
  date        DateTime
  durationMin Int
  type        TrainingType
  intensity   Int // 1-10
  notes       String?
  coach       String?
  mediaUrls   String[] // Supabase storage URLs (photos/videos)
  createdAt   DateTime     @default(now())

  @@index([playerId, date])
}

model ExerciseLog {
  id          String   @id @default(cuid())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id])
  date        DateTime
  activity    String // Running, Walking, Gym, Yoga, ...
  durationMin Int
  distanceKm  Float?
  calories    Int?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([playerId, date])
}

// ─── Discipline ──────────────────────────────────────────────────────────────

model DisciplineScore {
  id            String   @id @default(cuid())
  playerId      String
  player        Player   @relation(fields: [playerId], references: [id])
  weekStart     DateTime // Monday of the scored week
  attendance    Int
  punctuality   Int
  commitment    Int
  communication Int
  respect       Int
  teamwork      Int
  sportsmanship Int
  helpingOthers Int
  behaviour     Int
  overall       Int
  comment       String?
  createdAt     DateTime @default(now())

  @@unique([playerId, weekStart])
}

// ─── Ranking ─────────────────────────────────────────────────────────────────

enum RankingPeriod {
  WEEKLY
  MONTHLY
  SEASON
  CAREER
}

model RankingConfig {
  id                String @id @default("default")
  processWeight     Float  @default(0.6)
  performanceWeight Float  @default(0.3)
  improvementWeight Float  @default(0.1)
}

model RankingSnapshot {
  id               String        @id @default(cuid())
  playerId         String
  player           Player        @relation(fields: [playerId], references: [id])
  period           RankingPeriod
  periodStart      DateTime
  processScore     Float
  performanceScore Float
  improvementScore Float
  overallRating    Float
  battingScore     Float         @default(0)
  bowlingScore     Float         @default(0)
  fieldingScore    Float         @default(0)
  rank             Int
  previousRank     Int?
  createdAt        DateTime      @default(now())

  @@unique([playerId, period, periodStart])
  @@index([period, periodStart, rank])
}

// ─── AI insights, coach, notifications ───────────────────────────────────────

enum InsightKind {
  STRENGTH
  WEAKNESS
  WEEKLY_GOAL
  MONTHLY_GOAL
  SUGGESTION
  REPORT
}

model AiInsight {
  id        String      @id @default(cuid())
  playerId  String
  player    Player      @relation(fields: [playerId], references: [id])
  kind      InsightKind
  content   String
  createdAt DateTime    @default(now())

  @@index([playerId, createdAt])
}

model CoachMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

enum NotificationType {
  NEW_EVENT
  MATCH_ANNOUNCEMENT
  EVENT_REMINDER
  TRAINING_REMINDER
  DISCIPLINE_UPDATED
  AI_WEEKLY_REPORT
  RANKING_CHANGE
  ANNOUNCEMENT
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
}
