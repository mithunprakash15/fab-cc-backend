# Production env for the deployed backend (Render/Fly/etc).
# Copy the real values into your host's dashboard — do NOT commit real secrets.

# Supabase SESSION POOLER connection string (IPv4). Get it from:
# Supabase Dashboard → Database → Connection string → "Session pooler" (port 5432).
# The direct db.<ref>.supabase.co:5432 host is IPv6-only and won't work from most hosts.
DATABASE_URL=postgresql://postgres.rbkkawrqglewlvtnqhqr:YOUR_DB_PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres

JWT_SECRET=generate-a-long-random-string
JWT_REFRESH_SECRET=generate-another-long-random-string
ADMIN_PASSWORD=admin123

SUPABASE_URL=https://rbkkawrqglewlvtnqhqr.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=fabcc-media

FAB_TEAM_ID=7544665
PLAYER_DEFAULT_PASSWORD=123
# PORT is provided by the host automatically; the app reads process.env.PORT.
